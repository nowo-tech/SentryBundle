# PHPStan configuration for Sentry Bundle.
#
# Static analysis on src/ and tests/ (level 8). Run: make phpstan
parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
        - vendor/*
        - tests/Fixtures/*
    bootstrapFiles:
        - phpstan-stubs/RedisException.php
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        - identifier: method.alreadyNarrowedType
          path: tests/*
