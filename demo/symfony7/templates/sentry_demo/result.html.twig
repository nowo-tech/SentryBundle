{% extends 'base.html.twig' %}

{% block title %}{{ use_case }}{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="alert alert-info d-flex align-items-center" role="alert">
                <span class="badge bg-info me-2">Caso de uso</span>
                <strong>{{ use_case }}</strong>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <h1 class="card-title h4">{{ title }}</h1>
                    <p class="card-text">{{ message }}</p>
                    <div class="alert alert-secondary small mb-0" role="status">
                        <strong>Dónde ver el resultado:</strong> revisa los <strong>logs</strong> de la aplicación (<code>var/log/</code> o <code>docker-compose logs -f php</code>) y, si tienes <code>SENTRY_DSN</code> configurado, el proyecto en <strong>Sentry</strong>.
                    </div>
                    <a href="{{ path('sentry_demo_index') }}" class="btn btn-outline-primary mt-3">← Volver al índice de rutas</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
