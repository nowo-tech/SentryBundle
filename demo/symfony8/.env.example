# Copy to .env and adjust. Required so the container sees .env via volume mount (make up copies this if .env missing).
# https://symfony.com/doc/current/configuration.html#configuration-based-on-environment-variables

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> sentry ###
SENTRY_DSN=
###< sentry ###

# Port for the demo project
PORT=8001
