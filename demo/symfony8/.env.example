# Copy to .env and adjust. Required so the container sees .env via volume mount (make up copies this if .env missing).
# https://symfony.com/doc/current/configuration.html#configuration-based-on-environment-variables

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_this_secret_key_to_a_random_value
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> sentry ###
# Empty = Sentry disabled (demos work without a project). Or set a DSN from https://sentry.io (e.g. https://key@o123.ingest.sentry.io/123)
SENTRY_DSN=
###< sentry ###

# Port for the demo project
PORT=8001
