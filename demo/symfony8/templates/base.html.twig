<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %} – Sentry Bundle Demo</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">Sentry Bundle Demo</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">Inicio</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="sentryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Sentry – Casos de uso</a>
                            <ul class="dropdown-menu" aria-labelledby="sentryDropdown">
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_index') }}">Índice de rutas</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_capture_exception') }}">captureException</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_capture_message') }}">captureMessage</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_capture_error') }}">captureError</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_add_breadcrumb') }}">addBreadcrumb</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_set_user') }}">setUser</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_set_context') }}">setContext</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_complete_example') }}">completeExample</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_safe_operation') }}">safeOperation</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_access_denied') }}">access-denied (listener)</a></li>
                                <li><a class="dropdown-item" href="{{ path('sentry_demo_trigger_error') }}">trigger-error (SDK)</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container my-4">
            {% block body %}{% endblock %}
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
